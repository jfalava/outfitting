    "lint": "oxlint --type-aware",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.25.6",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-router": "1.163.3",
