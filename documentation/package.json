    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.19",
    "@tanstack/router-plugin": "1.168.14",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.10",
    "fumadocs-ui": "16.9.3",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.0",
    "vite-tsconfig-paths": "6.1.1"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
