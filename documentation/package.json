    "@tanstack/react-start": "1.168.27",
    "@tanstack/router-plugin": "1.168.19",
    "fumadocs-core": "16.11.1",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "16.11.1",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2",
    "vite-tsconfig-paths": "6.1.1"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@types/react": "19.2.17",
