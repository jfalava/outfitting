    "@tanstack/react-router-ssr-query": "1.163.3",
    "@tanstack/react-start": "1.165.0",
    "@tanstack/router-plugin": "1.164.0",
    "fumadocs-core": "16.6.8",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-ui": "16.6.8",
    "lucide-react": "0.575.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.1",
    "vite-tsconfig-paths": "6.1.1"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@types/react": "19.2.14",
