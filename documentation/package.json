{
  "name": "@outfitting/documentation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "check": "tsgo --noEmit && oxlint --type-aware --fix && oxfmt",
    "deploy": "wrangler types && tsgo --noEmit && oxlint --type-aware && oxfmt && vite build && wrangler deploy",
    "dev": "wrangler types && vite dev --port 3000 --host",
    "format": "oxfmt",
    "lint": "oxlint --type-aware",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.13.8",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.9.4",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "fumadocs-core": "^16.5.0",
    "fumadocs-mdx": "^14.2.6",
    "fumadocs-ui": "^16.5.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.6",
    "vite-tsconfig-paths": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "catalog:build",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^28.0.0",
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "oxlint-tsgolint": "catalog:build",
    "typescript": "catalog:build",
    "vite": "^8.0.0-beta.13",
    "wrangler": "catalog:build"
  }
}
