{
  "name": "@outfitting/installer",
  "version": "0.10.0",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "check": "tsgo --noEmit && oxlint --fix --type-aware",
    "deploy": "wrangler types && tsgo --noEmit && oxlint --type-aware && oxfmt && wrangler deploy",
    "dev": "bun run cf-typegen && wrangler dev",
    "format": "oxfmt",
    "lint": "oxlint --type-aware",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "hono": "4.12.3"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:build",
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "oxlint-tsgolint": "catalog:build",
    "typescript": "catalog:build",
    "wrangler": "catalog:build"
  }
}
