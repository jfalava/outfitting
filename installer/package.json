{
  "name": "@outfitting/installer",
  "version": "0.12.0",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "check": "tsc --noEmit && oxlint --fix",
    "deploy": "wrangler types && tsc --noEmit && oxlint && oxfmt && wrangler deploy",
    "dev": "bun run cf-typegen && wrangler dev",
    "format": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "4.12.31"
  },
  "devDependencies": {
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "oxlint-tsgolint": "catalog:build",
    "typescript": "catalog:build",
    "wrangler": "catalog:build"
  }
}
